---
---
<form id="contactForm" class="space-y-6">
  <!-- Name Input -->
  <div>
    <label class="block text-gray-700 mb-2" for="name">Name</label>
    <input 
      type="text" 
      id="name"
      name="name"
      required
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" 
    />
  </div>

  <!-- Email Input -->
  <div>
    <label class="block text-gray-700 mb-2" for="email">Email</label>
    <input 
      type="email" 
      id="email"
      name="email" 
      required
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" 
    />
  </div>

  <!-- Message Input -->
  <div>
    <label class="block text-gray-700 mb-2" for="message">Message</label>
    <textarea 
      id="message"
      name="message" 
      rows="4" 
      required
      class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all"
    ></textarea>
  </div>

  <!-- Submit Button -->
  <button 
    type="submit" 
    class="w-full bg-primary text-white px-8 py-4 rounded-lg text-lg font-medium hover:bg-blue-700 transition-all relative overflow-hidden group"
  >
    <span class="relative z-10">Send Message</span>
    <div class="absolute bottom-0 left-0 w-full h-full bg-blue-700 transform origin-left scale-x-0 transition-transform duration-500 group-hover:scale-x-100"></div>
    <div id="submitProgress" class="absolute bottom-0 left-0 w-0 h-1 bg-white transition-all duration-300"></div>
  </button>
</form>

<script>
  import emailjs from '@emailjs/browser';

  // Get form and elements
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const submitProgress = document.getElementById('submitProgress') as HTMLElement;
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  // Initialize EmailJS
  // Replace "YOUR_PUBLIC_KEY" with your EmailJS public key
  emailjs.init(import.meta.env.VITE_EMAILJS_PUBLIC_KEY);

  // Prevent multiple submissions
  let isSubmitting = false;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Prevent multiple submissions
      if (isSubmitting) {
        alert('Please wait before submitting again.');
        return;
      }

      // Validate inputs
      const name = form.querySelector('#name') as HTMLInputElement;
      const email = form.querySelector('#email') as HTMLInputElement;
      const message = form.querySelector('#message') as HTMLTextAreaElement;

      if (!name.value.trim() || !email.value.trim() || !message.value.trim()) {
        alert('All fields are required.');
        return;
      }

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email.value)) {
        alert('Please enter a valid email address.');
        return;
      }

      // Disable button and show progress bar
      isSubmitting = true;
      if (submitButton) {
        submitButton.disabled = true;
      }
      if (submitProgress) {
        submitProgress.style.width = '0%';
        submitProgress.style.opacity = '1';
      }

      try {
        // Simulate progress bar animation
        for (let i = 0; i <= 60; i += 20) {
          if (submitProgress) {
            submitProgress.style.width = `${i}%`;
          }
          await new Promise<void>((resolve) => setTimeout(resolve, 200));
        }

        // Send email using EmailJS
        await emailjs.sendForm(
          import.meta.env.VITE_EMAILJS_SERVICE_ID, // Replace with your EmailJS service ID
          import.meta.env.VITE_EMAILJS_TEMPLATE_ID, // Replace with your EmailJS template ID
          form,
          import.meta.env.VITE_EMAILJS_PUBLIC_KEY // Replace with your EmailJS public key
        );

        // Complete progress bar
        if (submitProgress) {
          submitProgress.style.width = '100%';
        }
        await new Promise(resolve => setTimeout(resolve, 300));

        // Show success message
        alert('Message sent successfully!');
        form.reset();
      } catch (error: unknown) {
        console.error('Error sending message:', error);
        alert('Failed to send message. Please check your internet connection or try again later.');
      } finally {
        // Reset the submit button and progress bar
        isSubmitting = false;
        if (submitButton) {
          submitButton.disabled = false; // Re-enable the button
        }
        if (submitProgress) {
          submitProgress.style.opacity = '0'; // Hide the progress bar
          submitProgress.style.width = '0%'; // Reset the progress bar width
        }
      }
    });
  }
</script>